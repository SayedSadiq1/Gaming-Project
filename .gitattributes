# Unity .gitattributes
# Controls how Git handles line endings and large/binary Unity files

# Default text handling
* text=auto

# Unity YAML files should stay text so Git can diff/merge them
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.renderTexture text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.inputactions text eol=lf

# C# and config files
*.cs text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf

# Images - binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.psd binary
*.tif binary
*.tiff binary
*.bmp binary
*.exr binary

# Audio - binary
*.wav binary
*.mp3 binary
*.ogg binary
*.aif binary
*.aiff binary

# Video - binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary

# 3D models - binary
*.fbx binary
*.blend binary
*.obj binary
*.dae binary
*.3ds binary

# Fonts - binary
*.ttf binary
*.otf binary

# Archives - binary
*.zip binary
*.rar binary
*.7z binary
*.unitypackage binary

# Visual Studio / IDE files
*.sln text eol=crlf
*.csproj text eol=crlf
